<div class="nav-rail-inner">
  <div class="nav-rail-chapters">
    <h2 class="nav-section-label" data-designation="Mandatory">Mandatory</h2>
    <ul class="nav-chapter-list">
      {% for entry in nav_groups["Mandatory"] %}
      <li class="nav-chapter-item{% if entry.label_status != 'ok' and entry.label_status != 'section_extraction_failed' %} nav-chapter-error{% endif %}">
        <a href="{{ entry.link_target }}">{{ entry.display_label }}</a>
        {% if entry.section_count > 0 %}
          <span class="nav-chapter-progress{% if entry.complete_count >= entry.section_count %} nav-chapter-progress--complete{% endif %}">
            {{ entry.complete_count }} / {{ entry.section_count }}
          </span>
        {% endif %}
      </li>
      {% else %}
      <li class="nav-chapter-empty">(none)</li>
      {% endfor %}
    </ul>

    <h2 class="nav-section-label" data-designation="Optional">Optional</h2>
    <ul class="nav-chapter-list">
      {% for entry in nav_groups["Optional"] %}
      <li class="nav-chapter-item{% if entry.label_status != 'ok' and entry.label_status != 'section_extraction_failed' %} nav-chapter-error{% endif %}">
        <a href="{{ entry.link_target }}">{{ entry.display_label }}</a>
        {% if entry.section_count > 0 %}
          <span class="nav-chapter-progress{% if entry.complete_count >= entry.section_count %} nav-chapter-progress--complete{% endif %}">
            {{ entry.complete_count }} / {{ entry.section_count }}
          </span>
        {% endif %}
      </li>
      {% else %}
      <li class="nav-chapter-empty">(none)</li>
      {% endfor %}
    </ul>
  </div>

</div>
