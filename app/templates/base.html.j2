<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block page_title %}CS 300{% endblock %}</title>
  <link rel="stylesheet" href="/static/lecture.css">
  <script>
    MathJax = {
      tex: {
        inlineMath: [['$', '$']],
        displayMath: [['\\[', '\\]']],
        processEscapes: true
      }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
</head>
<body>
  <div class="page-layout">
    <nav class="lecture-rail">
      {% include "_nav_rail.html.j2" %}
    </nav>
    <main class="page-main">
      {% block main %}{% endblock %}
    </main>
  </div>
</body>
</html>
