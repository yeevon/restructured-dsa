{% extends "base.html.j2" %}

{% block page_title %}{{ title }} — CS 300 Lecture{% endblock %}

{% block main %}
  <article class="lecture">

    <header class="lecture-header">
      <span class="designation-badge designation-{{ designation | lower }}">{{ designation }}</span>
      <h1 class="lecture-title">{{ title }}</h1>
    </header>

    {% if pre_section_html %}
    <div class="lecture-intro">
      {{ pre_section_html | safe }}
    </div>
    {% endif %}

    {% for section in sections %}
    <section id="{{ section.fragment }}">
      <h2 class="section-heading">{{ section.heading | safe }}</h2>
      <div class="section-body">
        {{ section.body_html | safe }}
      </div>
    </section>
    {% endfor %}

  </article>
{% endblock %}
